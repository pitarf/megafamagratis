# =========================================================================
# CONFIGURAÇÕES DE BANCO DE DADOS POSTGRESQL (DOCKER / PRODUÇÃO)
# =========================================================================
POSTGRES_DB=megafama
POSTGRES_USER=megafama_app
# Senha forte gerada aleatoriamente em produção
POSTGRES_PASSWORD=insira_uma_senha_forte_aqui

# URL de conexão com o banco de dados (Prisma). 
# Em produção, utilize o host do container "postgres".
# IMPORTANTE: codifique caracteres especiais como @ na senha (ex: Rafael@180 -> Rafael%40180)
DATABASE_URL=postgresql://megafama_app:insira_uma_senha_forte_aqui@postgres:5432/megafama?schema=public

# Diretórios persistentes locais da VPS (Mapeamento de Volumes)
POSTGRES_DATA_DIR=/opt/megafama/data/postgres
POSTGRES_BACKUP_DIR=/opt/megafama/backups/postgres

# =========================================================================
# CONFIGURAÇÕES DO ADMINISTRADOR INICIAL (PRIMEIRO ACESSO)
# =========================================================================
# Opcional: Define o email e senha do primeiro acesso. 
# A senha padrão "admin123" será rejeitada em produção por segurança!
ADMIN_EMAIL=admin@megafama.com
ADMIN_INITIAL_PASSWORD=insira_uma_senha_forte_e_inicial_aqui

# Senha em texto puro do admin (fallback para compatibilidade se necessário)
# Nota: Recomenda-se remover ou manter vazia em produção para usar os usuários do banco
ADMIN_PASSWORD=

# =========================================================================
# CONFIGURAÇÕES DE ENVIOS E FORNECEDOR (FALLBACKS INICIAIS)
# =========================================================================
SMM_API_URL=https://dukefornecedor.com/api/v2
SMM_API_KEY=
INSTAGRAM_FOLLOWERS_SERVICE_ID=
INSTAGRAM_LIKES_SERVICE_ID=
INSTAGRAM_VIEWS_SERVICE_ID=
TIKTOK_FOLLOWERS_SERVICE_ID=
TIKTOK_LIKES_SERVICE_ID=
TIKTOK_VIEWS_SERVICE_ID=
KWAI_FOLLOWERS_SERVICE_ID=
KWAI_LIKES_SERVICE_ID=
KWAI_VIEWS_SERVICE_ID=
